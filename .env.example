# ============================================================
# ROCKET ERP — Backend Environment Variables
# Copie para .env e preencha com seus valores reais
# NUNCA commite o .env no git!
# ============================================================

# Servidor
NODE_ENV=development
PORT=3001

# JWT
JWT_SECRET=coloque_aqui_uma_string_longa_e_aleatoria_min_32_chars
JWT_EXPIRES_IN=7d

# Supabase
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_do_supabase

# Espião Cloud API
ESPIO_BASE_URL=http://api.espiaonfe.com.br
# Os tokens são por conta/usuário — armazenados no banco por empresa

# Google Cloud Storage (alternativa ao Supabase Storage)
GCS_BUCKET=rocket-erp-docs

# Configurações de upload
MAX_FILE_SIZE_MB=50
ALLOWED_UPLOAD_TYPES=csv,xlsx,xls,json,xml,ofx,txt,pdf,jpg,jpeg,png

# CORS — domínios permitidos (separados por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,https://app.seudominio.com.br
